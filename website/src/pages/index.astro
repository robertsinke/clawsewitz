---
import Layout from '../layouts/main.astro';
import '../styles/global.css';
---
<Layout title="clawsewitz — the open source AI strategy agent">

<!-- Hero -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center pt-16 pb-8">
  <h1 class="text-center tracking-tight text-text-primary font-bold text-4xl sm:text-5xl leading-[1.15]">
    The open source AI<br/>strategy agent
  </h1>
  <p class="text-center mt-4 max-w-3xl text-text-secondary text-base leading-relaxed">
    Decomposes problems, runs 70 frameworks, stress-tests plans, writes executive briefs, and builds implementation roadmaps. All inside Claude Code.
  </p>

  <!-- Install tabs -->
  <div id="install" class="flex flex-col items-center mt-8 w-full max-w-4xl">
    <div class="flex self-start -mb-px">
      <button id="tab-curl" class="py-2 px-4 bg-prussian-tint rounded-t-lg text-text-primary font-medium text-[13px]" onclick="document.getElementById('code-curl').classList.remove('hidden');document.getElementById('code-manual').classList.add('hidden');this.classList.add('bg-prussian-tint');document.getElementById('tab-manual').classList.remove('bg-prussian-tint')">curl</button>
      <button id="tab-manual" class="py-2 px-4 text-text-secondary text-[13px]" onclick="document.getElementById('code-manual').classList.remove('hidden');document.getElementById('code-curl').classList.add('hidden');this.classList.add('bg-prussian-tint');document.getElementById('tab-curl').classList.remove('bg-prussian-tint')">manual</button>
    </div>
    <div id="code-curl" class="w-full flex items-center justify-between gap-3 rounded-bl-lg rounded-r-lg py-4 px-5 bg-prussian-tint">
      <code id="curl-text" class="font-mono text-[12px] text-text-primary whitespace-nowrap overflow-x-auto">curl -fsSL https://robertsinke.github.io/clawsewitz/install | bash</code>
      <button onclick="navigator.clipboard.writeText(document.getElementById('curl-text').textContent)" class="shrink-0 p-1.5 rounded hover:bg-prussian/10 transition-colors" title="Copy">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
    </div>
    <div id="code-manual" class="hidden w-full flex items-start justify-between gap-3 rounded-bl-lg rounded-r-lg py-4 px-5 bg-prussian-tint">
      <div id="manual-text" class="flex flex-col gap-1">
        <code class="font-mono text-[12px] text-text-primary">git clone --depth 1 https://github.com/robertsinke/clawsewitz \</code>
        <code class="font-mono text-[12px] text-text-primary pl-4">~/.claude/plugins/local/clawsewitz</code>
        <code class="font-mono text-[12px] text-text-primary mt-1">claude plugin marketplace add ~/.claude/plugins/local/clawsewitz</code>
        <code class="font-mono text-[12px] text-text-primary">claude plugin install clawsewitz@clawsewitz-local</code>
      </div>
      <button onclick="navigator.clipboard.writeText(document.getElementById('manual-text').textContent.trim())" class="shrink-0 p-1.5 rounded hover:bg-prussian/10 transition-colors mt-0.5" title="Copy">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
    </div>
  </div>

  <!-- CTAs -->
  <div class="flex items-center mt-6 gap-4">
    <a href={`${import.meta.env.BASE_URL}/docs/installation`} class="rounded-lg py-2.5 px-6 bg-prussian text-prussian-tint font-semibold text-sm hover:bg-prussian-dark transition-colors">Get Started</a>
    <a href="https://github.com/robertsinke/clawsewitz" class="flex items-center gap-1.5 text-text-secondary font-medium text-sm hover:text-text-primary transition-colors">
      GitHub
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </div>
  <div class="flex flex-col items-center mt-3 gap-1">
    <span class="text-[13px] text-text-muted">Use curl for the full plugin, or install manually with git.</span>
    <a href={`${import.meta.env.BASE_URL}/docs/installation#skills-only`} class="text-[13px] text-prussian underline underline-offset-2">Need just the skills? Install the skills-only bundle.</a>
  </div>

  <!-- Terminal -->
  <div class="w-full mt-10 flex flex-col rounded-xl overflow-hidden bg-terminal-bg shadow-[0_20px_60px_-15px_rgba(13,21,32,0.5)]">
    <div class="flex items-center py-3 px-4 gap-2 bg-terminal-bar">
      <div class="size-3 rounded-full bg-[#EE5555] shrink-0"></div>
      <div class="size-3 rounded-full bg-[#E5A825] shrink-0"></div>
      <div class="size-3 rounded-full bg-[#3DBA4E] shrink-0"></div>
      <span class="text-xs text-text-secondary mx-auto">clawsewitz</span>
    </div>
    <div class="flex flex-col py-5 px-6 items-center">
      <div class="font-pixel text-prussian-accent text-[80px] sm:text-[120px] leading-none tracking-wide select-none">
        clawsewitz
      </div>
      <div class="flex mt-4 rounded border border-prussian overflow-hidden text-[10px] sm:text-[11px] w-full">
        <div class="flex flex-col gap-3 border-r border-prussian shrink-0 p-4 w-48 sm:w-60 overflow-hidden min-w-0">
          <pre class="font-mono text-text-muted leading-relaxed whitespace-pre overflow-hidden min-w-0">model     claude-opus-4-6
directory ~/.claude/clawsewitz
session   a7f3c1d2...

system    8 cores · 16GB

11 skills · 4 agents</pre>
          <div class="flex flex-col gap-0.5">
            <span class="font-mono font-bold text-prussian-accent">Agents</span>
            <span class="font-mono text-text-muted">researcher, analyst, writer, challenger</span>
          </div>
        </div>
        <div class="flex flex-col gap-1 p-4 flex-1 min-w-0 overflow-x-auto">
          <span class="font-mono font-bold text-prussian-accent">Workflows</span>
          <pre class="font-mono text-text-muted leading-relaxed whitespace-pre">/clawsewitz    full strategic engagement
/cw-decompose  MECE problem decomposition
/cw-brief      executive brief or memo
/cw-audit      red-team + premortem review
/cw-evaluate   weighted criteria scoring
/cw-research   competitive intelligence
/cw-plan       implementation roadmap
/cw-case       manage case workspaces
/cw-frameworks browse 70 frameworks</pre>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- What you type → what happens -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">What you type &rarr; what happens</h2>
  <p class="text-center mt-2 text-[15px] text-text-secondary">Slash commands or natural language. Your call.</p>
  <div class="w-full mt-8 flex flex-col rounded-xl py-6 px-7 gap-4 bg-surface-card">
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">/clawsewitz "Acme — subscriber decline, 5%/mo, need turnaround"</code>
      <span class="text-[13px] text-text-secondary">Full 7-step engagement with structured deliverables at every stage</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">/cw-decompose "Why are enterprise customers churning at 2x the SMB rate?"</code>
      <span class="text-[13px] text-text-secondary">Problem framing + MECE decomposition tree with automated validation</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">/cw-audit path/to/strategy-doc.md</code>
      <span class="text-[13px] text-text-secondary">Red-team review + premortem narrative with risk register</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">/cw-evaluate "Build vs. buy vs. partner for the data platform"</code>
      <span class="text-[13px] text-text-secondary">Weighted criteria scoring + recommendation</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">/cw-research "Competitive landscape for AI code review tools"</code>
      <span class="text-[13px] text-text-secondary">Structured research brief with sources, comparative table, and gaps</span>
    </div>
  </div>
</section>

<!-- Workflows -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">Workflows</h2>
  <p class="text-center mt-2 text-[15px] text-text-secondary">Nine commands. Each produces a deliverable.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-8 w-full">
    {[
      { cmd: '/clawsewitz', desc: 'Full strategic engagement — brief to implementation plan' },
      { cmd: '/cw-decompose', desc: 'Break a problem into a validated MECE tree' },
      { cmd: '/cw-brief', desc: 'Write an executive brief or recommendation memo' },
      { cmd: '/cw-audit', desc: 'Red-team and premortem an existing plan' },
      { cmd: '/cw-evaluate', desc: 'Score options against criteria and recommend one' },
      { cmd: '/cw-research', desc: 'Gather competitive, market, or industry intelligence' },
      { cmd: '/cw-plan', desc: 'Build an implementation roadmap with risk register' },
      { cmd: '/cw-case', desc: 'List, resume, or archive engagement workspaces' },
      { cmd: '/cw-frameworks', desc: 'Browse or look up any of 70 strategy frameworks' },
    ].map((wf) => (
      <div class="flex flex-col rounded-xl gap-1.5 bg-surface-card p-5">
        <code class="font-mono text-[13px] font-semibold text-prussian">{wf.cmd}</code>
        <p class="text-[13px] leading-5 text-text-secondary">{wf.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- Strategy Loop -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">Strategy Loop</h2>
  <p class="text-center mt-2 text-[15px] text-text-secondary">Seven stages. Each produces a deliverable. Hooks enforce the chain.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-8 w-full">
    {[
      { cmd: '/define', desc: 'Frame the problem with SCQ, HTDQ, or Outcome.', output: 'problem statement, success criteria, stakeholder map' },
      { cmd: '/split', desc: 'MECE decomposition via Driver Tree, Bucketing, or Hypothesis Tree.', output: 'validated tree, center-of-gravity analysis, MECE verdict' },
      { cmd: '/analyse', desc: 'Run analyses with 70+ frameworks on each leg of the tree.', output: 'data tables, financial models, qualitative assessments' },
      { cmd: '/insight', desc: 'Mount takeaways on page archetypes: Canvas, 2×2, Journey Map.', output: 'insight pages, HTML visualizations, gap analysis' },
      { cmd: '/story', desc: 'Stitch insights into a structured narrative via Minto Pyramid.', output: 'executive memo, governing thought, slide outline' },
      { cmd: '/decide', desc: 'Recommendation using SPADE, Bezos, or Evaluation Matrix.', output: 'scored options, recommendation, adversarial review' },
      { cmd: '/act', desc: 'Implementation plan with risk register and reserves.', output: 'roadmap, workstreams, milestones, premortem narrative' },
    ].map((stage) => (
      <div class="flex flex-col rounded-xl gap-2.5 justify-between bg-surface-card p-5">
        <div>
          <code class="font-mono text-[13px] font-semibold text-prussian">{stage.cmd}</code>
          <p class="mt-1.5 text-[13px] leading-5 text-text-secondary">{stage.desc}</p>
        </div>
        <div class="mt-auto">
          <span class="font-mono text-xs text-text-muted">Produces: {stage.output}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Agents -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">Agents</h2>
  <p class="text-center mt-2 text-[15px] text-text-secondary">You ask a question. The right team assembles.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-8 w-full">
    {[
      { name: 'Researcher', desc: 'Hunts for evidence across the web, benchmarks, and competitive landscape' },
      { name: 'Analyst', desc: 'Decomposes problems, applies frameworks, validates MECE integrity, names the weakest link' },
      { name: 'Writer', desc: 'Structures findings into briefs, memos, and slide narratives' },
      { name: 'Challenger', desc: 'Stress-tests plans, plays adversary, writes the failure narrative' },
    ].map((agent) => (
      <div class="flex flex-col items-center rounded-xl gap-1.5 bg-surface-card p-5 text-center">
        <span class="font-semibold text-sm text-text-primary">{agent.name}</span>
        <span class="text-[13px] leading-5 text-text-secondary">{agent.desc}</span>
      </div>
    ))}
  </div>
</section>

<!-- Skills & Tools -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">Skills & Tools</h2>
  <p class="text-center mt-2 text-[15px] text-text-secondary">How clawsewitz searches, structures, and delivers.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-8 w-full">
    {[
      { name: 'Framework Library', desc: '70 frameworks with definitions, worked examples, and step-by-step instructions' },
      { name: 'Web Search', desc: 'Competitive landscape, market data, industry benchmarks, and recent news' },
      { name: 'Session Search', desc: 'Search across past engagements — find prior analyses, decisions, and deliverables' },
      { name: 'Preview', desc: 'Render HTML visualizations: Canvas, 2×2 Matrix, Journey Map, Positioning Map' },
    ].map((tool) => (
      <div class="flex flex-col items-center rounded-xl gap-1.5 bg-surface-card p-5 text-center">
        <span class="font-semibold text-sm text-text-primary">{tool.name}</span>
        <span class="text-[13px] leading-5 text-text-secondary">{tool.desc}</span>
      </div>
    ))}
  </div>
</section>

</Layout>
