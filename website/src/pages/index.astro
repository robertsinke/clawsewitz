---
import Layout from '../layouts/main.astro';
import '../styles/global.css';
---
<Layout title="clawsewitz — the open source AI strategy agent">

<!-- Hero -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center pt-16 pb-8">
  <h1 class="text-center tracking-tight text-text-primary font-bold text-4xl sm:text-5xl leading-[1.15]">
    The open source AI<br/>strategy agent
  </h1>
  <p class="text-center mt-4 max-w-3xl text-text-secondary text-base leading-relaxed">
    Decomposes problems, runs 70 frameworks, stress-tests plans, writes executive briefs, and builds implementation roadmaps.
  </p>

  <!-- Install tabs -->
  <div id="install" class="flex flex-col items-center mt-8 w-full max-w-4xl">
    <div class="flex self-start -mb-px">
      <button id="tab-npm" class="py-2 px-4 bg-prussian-tint rounded-t-lg text-text-primary font-medium text-[13px]" onclick="showTab('npm')">npm</button>
      <button id="tab-curl" class="py-2 px-4 text-text-secondary text-[13px]" onclick="showTab('curl')">curl</button>
      <button id="tab-plugin" class="py-2 px-4 text-text-secondary text-[13px]" onclick="showTab('plugin')">claude code</button>
    </div>
    <div id="code-npm" class="w-full flex items-center justify-between gap-3 rounded-bl-lg rounded-r-lg py-4 px-5 bg-prussian-tint">
      <code id="npm-text" class="font-mono text-[12px] text-text-primary whitespace-nowrap overflow-x-auto">npm install -g clawsewitz</code>
      <button onclick="navigator.clipboard.writeText(document.getElementById('npm-text').textContent)" class="shrink-0 p-1.5 rounded hover:bg-prussian/10 transition-colors" title="Copy">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
    </div>
    <div id="code-curl" class="hidden w-full flex items-center justify-between gap-3 rounded-bl-lg rounded-r-lg py-4 px-5 bg-prussian-tint">
      <code id="curl-text" class="font-mono text-[12px] text-text-primary whitespace-nowrap overflow-x-auto">curl -fsSL https://robertsinke.github.io/clawsewitz/install | bash</code>
      <button onclick="navigator.clipboard.writeText(document.getElementById('curl-text').textContent)" class="shrink-0 p-1.5 rounded hover:bg-prussian/10 transition-colors" title="Copy">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
    </div>
    <div id="code-plugin" class="hidden w-full flex items-center justify-between gap-3 rounded-bl-lg rounded-r-lg py-4 px-5 bg-prussian-tint">
      <code id="plugin-text" class="font-mono text-[12px] text-text-primary whitespace-nowrap overflow-x-auto">curl -fsSL https://robertsinke.github.io/clawsewitz/install-plugin | bash</code>
      <button onclick="navigator.clipboard.writeText(document.getElementById('plugin-text').textContent)" class="shrink-0 p-1.5 rounded hover:bg-prussian/10 transition-colors" title="Copy">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      </button>
    </div>
  </div>

  <script is:inline>
  function showTab(tab) {
    for (const id of ['npm', 'curl', 'plugin']) {
      document.getElementById('code-' + id).classList.toggle('hidden', id !== tab);
      const btn = document.getElementById('tab-' + id);
      btn.classList.toggle('bg-prussian-tint', id === tab);
      btn.classList.toggle('text-text-primary', id === tab);
      btn.classList.toggle('font-medium', id === tab);
      btn.classList.toggle('text-text-secondary', id !== tab);
    }
  }
  </script>

  <!-- CTAs -->
  <div class="flex items-center mt-6 gap-4">
    <a href={`${import.meta.env.BASE_URL}/docs/installation`} class="rounded-lg py-2.5 px-6 bg-prussian text-prussian-tint font-semibold text-sm hover:bg-prussian-dark transition-colors">Get Started</a>
    <a href="https://github.com/robertsinke/clawsewitz" class="flex items-center gap-1.5 text-text-secondary font-medium text-sm hover:text-text-primary transition-colors">
      GitHub
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </div>
  <div class="flex flex-col items-center mt-3 gap-1">
    <span class="text-[13px] text-text-muted">Also available as a <a href={`${import.meta.env.BASE_URL}/docs/installation#plugin`} class="text-prussian underline underline-offset-2">Claude Code plugin</a> or <a href={`${import.meta.env.BASE_URL}/docs/installation#skills-only`} class="text-prussian underline underline-offset-2">skills-only bundle</a>.</span>
  </div>

  <!-- Terminal -->
  <div class="w-full mt-10 flex flex-col rounded-xl overflow-hidden bg-terminal-bg ring-1 ring-prussian/10 shadow-[0_20px_60px_-15px_rgba(15,42,74,0.15)]">
    <div class="flex items-center py-3 px-4 gap-2 bg-terminal-bar border-b border-prussian/10">
      <div class="size-3 rounded-full bg-[#EE5555] shrink-0"></div>
      <div class="size-3 rounded-full bg-[#E5A825] shrink-0"></div>
      <div class="size-3 rounded-full bg-[#3DBA4E] shrink-0"></div>
      <span class="text-xs text-text-secondary mx-auto">clawsewitz &mdash; robertsinke</span>
    </div>

    <div class="flex flex-col py-5 px-6 items-center">
      <img src={`${import.meta.env.BASE_URL}/wordmark.svg`} alt="clawsewitz" class="select-none w-full max-w-md h-auto" />
      <span class="mt-2 font-mono text-[11px] text-text-muted">v1.0.0</span>

      <div class="flex mt-4 rounded border border-prussian/20 overflow-hidden text-[10px] sm:text-[11px] w-full">
        <div class="flex flex-col gap-3 border-r border-prussian/20 shrink-0 p-4 w-60 sm:w-72 min-w-0">
          <pre class="font-mono text-text-muted leading-relaxed whitespace-pre min-w-0">model     claude-opus-4-6
directory ~/.claude/clawsewitz
session   a7f3c1d2...

system    8 cores &middot; 16GB

agents    4
workflows 8
skills    9</pre>
          <div class="flex flex-col gap-0.5">
            <span class="font-mono font-bold text-prussian-accent">Agents</span>
            <span class="font-mono text-text-muted">researcher, analyst,<br/>writer, challenger</span>
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="font-mono font-bold text-prussian-accent">Last Activity</span>
            <span class="font-mono text-text-muted">decompose &middot; SMB churn drivers</span>
          </div>
        </div>
        <div class="flex flex-col gap-1 p-4 flex-1 min-w-0 overflow-x-auto">
          <span class="font-mono font-bold text-prussian-accent">Strategy Workflows</span>
          <pre class="font-mono text-text-muted leading-relaxed whitespace-pre">/decompose     MECE problem decomposition
/evaluate      weighted criteria scoring
/brief         executive brief or memo
/plan          implementation roadmap
/audit         red-team + premortem review
/research      competitive intelligence
/case          manage case workspaces
/frameworks    browse 70 frameworks</pre>
        </div>
      </div>
    </div>

    <!-- Sample interaction -->
    <div class="flex flex-col gap-3 px-6 py-5 border-t border-prussian/10 bg-prussian-tint/40">
      <p class="font-mono text-[12px] text-text-primary"><span class="text-prussian-accent font-bold">&gt;</span> Should we build, buy, or partner for the data platform?</p>
      <p class="font-mono text-[11px] italic text-text-secondary leading-relaxed">A build-vs-buy-vs-partner question. Three options across cost, speed, ops burden, lock-in, and team fit. Routing to the analyst for a weighted evaluation, then the challenger for a premortem on the recommendation.</p>
      <div class="flex flex-col gap-1 font-mono text-[11px]">
        <span class="text-prussian-accent">evaluate <span class="text-text-muted">weighted criteria scoring</span></span>
        <pre class="text-text-muted leading-relaxed whitespace-pre-wrap">  options:   build in-house · buy Snowflake · partner Databricks
  criteria:  cost, ramp time, ops burden, lock-in, team fit
  weights:   0.20, 0.25, 0.25, 0.15, 0.15
scored 3 options across 5 criteria &middot; 14 sources
Snowflake wins (3.8) &mdash; ramp time and ops burden carry it.</pre>
      </div>
    </div>
  </div>
</section>

<!-- What you type → what happens -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">What you type &rarr; what happens</h2>
  <p class="text-center mt-2 text-[15px] text-text-secondary">Run from any terminal. Each command launches a focused workflow.</p>
  <div class="w-full mt-8 flex flex-col rounded-xl py-6 px-7 gap-4 bg-surface-card">
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">clawsewitz decompose "Why are enterprise customers churning at 2x the SMB rate?"</code>
      <span class="text-[13px] text-text-secondary">Problem framing + MECE decomposition tree with automated validation</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">clawsewitz audit path/to/strategy-doc.md</code>
      <span class="text-[13px] text-text-secondary">Red-team review + premortem narrative with risk register</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">clawsewitz evaluate "Build vs. buy vs. partner for the data platform"</code>
      <span class="text-[13px] text-text-secondary">Weighted criteria scoring + recommendation</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <code class="font-mono text-[13px] font-semibold text-prussian">clawsewitz research "Competitive landscape for AI code review tools"</code>
      <span class="text-[13px] text-text-secondary">Structured research brief with sources, comparative table, and gaps</span>
    </div>
  </div>
</section>

<!-- Workflows -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">Workflows</h2>
  <p class="text-center mt-2 max-w-2xl text-[15px] text-text-secondary">Eight things you can ask for. Each produces a deliverable. Trigger by slash command, by natural language (an auto-routing skill picks the workflow), or by the standalone CLI prompt.</p>
  <p class="text-center mt-2 max-w-2xl text-[13px] text-text-muted">New brief? Skip the menu — just describe the problem. The <code class="font-mono text-prussian">engagement-intake</code> skill triages it, asks the missing questions, and routes to the right workflow.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-8 w-full">
    {[
      { cmd: '/decompose', desc: 'Break a problem into a validated MECE tree' },
      { cmd: '/brief', desc: 'Write an executive brief or recommendation memo' },
      { cmd: '/audit', desc: 'Red-team and premortem an existing plan' },
      { cmd: '/evaluate', desc: 'Score options against criteria and recommend one' },
      { cmd: '/research', desc: 'Gather competitive, market, or industry intelligence' },
      { cmd: '/plan', desc: 'Build an implementation roadmap with risk register' },
      { cmd: '/case', desc: 'List, resume, or archive engagement workspaces' },
      { cmd: '/frameworks', desc: 'Browse or look up any of 70 strategy frameworks' },
    ].map((wf) => (
      <div class="flex flex-col rounded-xl gap-1.5 bg-surface-card p-5">
        <code class="font-mono text-[13px] font-semibold text-prussian">{wf.cmd}</code>
        <p class="text-[13px] leading-5 text-text-secondary">{wf.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- Agents -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">Agents</h2>
  <p class="text-center mt-2 text-[15px] text-text-secondary">You ask a question. The right team assembles.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-8 w-full">
    {[
      { name: 'Researcher', desc: 'Hunts for evidence across the web, benchmarks, and competitive landscape' },
      { name: 'Analyst', desc: 'Decomposes problems, applies frameworks, validates MECE integrity, names the weakest link' },
      { name: 'Writer', desc: 'Structures findings into briefs, memos, and slide narratives' },
      { name: 'Challenger', desc: 'Stress-tests plans, plays adversary, writes the failure narrative' },
    ].map((agent) => (
      <div class="flex flex-col items-center rounded-xl gap-1.5 bg-surface-card p-5 text-center">
        <span class="font-semibold text-sm text-text-primary">{agent.name}</span>
        <span class="text-[13px] leading-5 text-text-secondary">{agent.desc}</span>
      </div>
    ))}
  </div>
</section>

<!-- Tools -->
<section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16">
  <h2 class="text-center tracking-tight text-text-primary font-bold text-3xl">Tools</h2>
  <p class="text-center mt-2 max-w-xl text-[15px] text-text-secondary">What the agent reaches for inside a workflow — not separate things you invoke.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-8 w-full">
    {[
      { name: 'Framework Library', desc: '70 frameworks with definitions, worked examples, and step-by-step instructions' },
      { name: 'Web Search', desc: 'Competitive landscape, market data, industry benchmarks, and recent news' },
      { name: 'Session Search', desc: 'Recall prior engagements — past analyses, decisions, and deliverables' },
      { name: 'Visualizations', desc: 'Render HTML diagrams: Canvas, 2×2 Matrix, Journey Map, Positioning Map' },
    ].map((tool) => (
      <div class="flex flex-col items-center rounded-xl gap-1.5 bg-surface-card p-5 text-center">
        <span class="font-semibold text-sm text-text-primary">{tool.name}</span>
        <span class="text-[13px] leading-5 text-text-secondary">{tool.desc}</span>
      </div>
    ))}
  </div>
</section>

</Layout>
