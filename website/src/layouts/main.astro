---
const { title = 'clawsewitz' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="The open source AI strategy agent. Decomposes problems, runs 70 frameworks, stress-tests plans, writes executive briefs, and builds implementation roadmaps." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
</head>
<body class="min-h-screen bg-surface font-sans text-text-primary antialiased">
  <!-- Nav -->
  <nav class="sticky top-0 z-50 h-14 bg-surface/80 backdrop-blur-md border-b border-prussian/10">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 h-full flex items-center justify-between">
      <a href={import.meta.env.BASE_URL} class="flex items-center"><img src={`${import.meta.env.BASE_URL}/wordmark.svg`} alt="clawsewitz" class="h-3" /></a>
      <div class="flex items-center gap-8">
        <a href={`${import.meta.env.BASE_URL}/docs/installation`} class="text-sm text-text-secondary hover:text-text-primary transition-colors">Docs</a>
        <a href="https://github.com/robertsinke/clawsewitz" class="text-sm text-text-secondary hover:text-text-primary transition-colors">GitHub</a>
      </div>
    </div>
  </nav>

  <slot />

  <!-- Footer CTA -->
  <section class="max-w-6xl mx-auto px-6 sm:px-8 flex flex-col items-center py-16 gap-5">
    <p class="text-center max-w-xl text-[15px] leading-6 text-text-secondary">
      Built on Pi. Run from any terminal, or install as a Claude Code plugin. Every deliverable follows the Strategy Loop.
    </p>
    <div class="flex items-center gap-4">
      <a href={`${import.meta.env.BASE_URL}/docs/installation`} class="rounded-lg py-2.5 px-6 bg-prussian text-prussian-tint font-semibold text-sm hover:bg-prussian-dark transition-colors">Get Started</a>
      <a href="https://github.com/robertsinke/clawsewitz" class="text-text-secondary font-medium underline underline-offset-2 text-sm hover:text-text-primary transition-colors">View on GitHub</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-prussian/10">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 h-14 flex items-center justify-between">
      <span class="text-[13px] text-text-muted">© 2026 Robert Sinke</span>
      <div class="flex gap-5">
        <a href={`${import.meta.env.BASE_URL}/docs/installation`} class="text-[13px] text-text-secondary hover:text-text-primary transition-colors">Docs</a>
        <a href="https://github.com/robertsinke/clawsewitz" class="text-[13px] text-text-secondary hover:text-text-primary transition-colors">GitHub</a>
      </div>
    </div>
  </footer>
</body>
</html>
